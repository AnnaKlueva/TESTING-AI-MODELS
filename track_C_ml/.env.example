# Проєкт працює БЕЗ API-ключів. Єдине, що треба, — обрати трек.
# Задай змінну середовища перед запуском: локально `export TRACK=C`,
# у Colab: os.environ['TRACK']='C' (файл .env код не читає — це лише шпаргалка).
TRACK=C          # A = chatbot, B = rag, C = ml, D = agent

# Опційно: якщо використовуєш API-модель для LLM-as-judge / генерації (див. README).
# Ключ живе ТІЛЬКИ в .env або змінній середовища — НІКОЛИ не комітиться.
# OPENAI_API_KEY=
